@page "/"
@using System.Numerics
@using System.Text.Json
@using System.Text.RegularExpressions
@using Step
@using Step.Binding
@using Step.Exceptions
@using Step.Interpreter
@using Step.Output
@using Step.Tasks
@using Step.Tasks.Primitives
@using StepRepl.GraphVisualization
@using Task = System.Threading.Tasks.Task
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Step</PageTitle>

<h3>Program</h3>

<div id="codeEditor" class="language-step">

</div>

<p>Control-click on a task/predicate name to navigate to its definition (only works for your own tasks, not built-in tasks)</p>
  
<script type="module">
    import { CodeJar } from 'https://cdn.jsdelivr.net/npm/codejar@3.3.0/codejar.min.js';
    import { withLineNumbers } from 'https://cdn.jsdelivr.net/npm/codejar@3.3.0/linenumbers.min.js';
    
    function tokenUnderCursor(event) {
        const caretPosition = document.caretPositionFromPoint(event.clientX, event.clientY);
        const text = caretPosition.offsetNode.textContent
        const start = caretPosition.offset;
        const before = text.slice(0,start);
        const preTokenOffset = before.search(/(^|[^A-Za-z0-9_])[A-Za-z0-9_]+$/);
        if (preTokenOffset < 0) return "nothing before";
        const after = text.slice(start);
        let postTokenOffset = after.search(/[^A-Za-z0-9_]/);
        if (postTokenOffset < 0) postTokenOffset = after.length;
        return before.slice(preTokenOffset) + after.slice(0, postTokenOffset);
    }
    
    function gotoDefinition(name) {
        const pattern = "(^|\\n|\\r)"+name+"[^A-Za-z0-9_]";
        const content = editor.textContent;
        let start = content.search(pattern);
        if (start > 0) start++;
        if (start >= 0)
        {
            editor.focus();
            editor.textContent = content.substring(0, start+1);
            editor.scrollTop = start;
            const realScrollTop = editor.scrollTop;
            editor.textContent = content;
            highlight(editor);
            jar.restore({start: start, end: start });
            if (realScrollTop < editor.clientHeight)
                editor.scrollTop = realScrollTop;
            else
                editor.scrollTop = realScrollTop + editor.clientHeight /2;
        }
        else
            console.log("Can't find: "+name);
    }

    const highlight = editor => {
      // highlight.js does not trims old tags,
      // let's do it by this hack.
      editor.textContent = editor.textContent;
      delete editor.dataset.highlighted;
      hljs.highlightElement(editor);
    };
    
    const editor = document.querySelector(".language-step");
    const jar = CodeJar(editor, withLineNumbers(highlight));

    // Put jar someplace the non-module scripts can find it.
    window.jar = jar;
    
    let dirty = false;
    
    editor.addEventListener("click", function(event) {
        if (!event.ctrlKey)
            return;
        event.preventDefault();
        const name = tokenUnderCursor(event);
        if (/^[A-Z][A-Za-z0-9_]*$/.test(name))
            gotoDefinition(name);
        else
            console.log("Token is not a name: "+name);
    });

    window.addEventListener('message', function(event) {
        if (event.source == window.opener)
        {
            var message = event.data;
            if (typeof message === "string")
            {
                jar.updateCode(DotNet.invokeMethod('StepWasmStandalone', 'SetSource', message));
                dirty = false;
            } else if (typeof message === "object" && "packageRepository" in message)
                packageRepository = message.packageRepository;
        } else
            console.log("wrong message sender");
    } );

    window.addEventListener("beforeunload", function (event) {
        if (dirty) {
            event.preventDefault();
            event.returnValue = '';
        }
    });

    document.getElementById('downloadButton').addEventListener('click', function() {
        // Create a Blob object with the content
        const blob = new Blob([jar.toString()], { type: "text/plain" });

        // Create a temporary anchor element
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = "Saved.step"; // Set the file name

        // Append the anchor to the document, trigger the download, and remove it
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
    });

    if (window.opener != null)
        window.opener.postMessage("_ready_", "*");
</script>

<script>
    function GetUserCode() {
        console.log("GetUserCode");
        return jar.toString();
    }

    function SetUserCode(source) {
        console.log("SetUserCode: "+source);
        jar.updateCode(source);
    }

    function LogIt(s) {
        console.log(s);
    }

    function ScheduleMermaidRenderAndScollToEnd() {
        window.requestAnimationFrame(function() {
            mermaid.run();
            window.requestAnimationFrame(function() { window.scrollTo(0, document.body.scrollHeight); });
        });
    }

    if (typeof packageRepository === 'undefined')
        packageRepository = window.location.href.substring(0, window.location.href.lastIndexOf('/') + 1);

    async function FetchPackage(packageName) {
        const packageUrl = packageRepository + packageName + ".step";
        console.log("Package URL: "+packageUrl);
        const response = await fetch(packageUrl);
        if (!response.ok)
            return null;
        return await response.text();
    }
</script>

@* <textarea @bind="@source" id="sourceCode" style="width: 800px; height: 400px;" spellcheck="false"/> *@
<br>
<button class="btn btn-primary" id="downloadButton">Download program</button>

<h3 style="padding-top: 2rem;">Command(s) to execute</h3>

<input @bind="@command" style="width:400px;" spellcheck="false" @onkeydown="@Enter"/>

<button class="btn btn-primary" @onclick="Run">Run</button>

@code {
    private static Module ReplUtilities = MakeReplUtilities();
    private static Module UserModule = null!;
    internal static State State;

    private string command ="";

    private string outputHeading = "No output";
    private MarkupString output = new MarkupString("no output");

    private async void Enter(KeyboardEventArgs e)
    {
        if (e.Code == "Enter")
        {
            StateHasChanged();
            await Task.Delay(1);
            Run();
        }
    }

    const string CommandCommentPrefix = "# Try:";

    [JSInvokable]
    public static string SetSource(string sourceCode)
    {
        if (sourceCode.StartsWith(CommandCommentPrefix))
        {
            var commandStart = CommandCommentPrefix.Length;
            var commandEnd = sourceCode.IndexOf('\n');
            singleton.command = sourceCode.Substring(commandStart, commandEnd-commandStart).Trim();
            sourceCode = sourceCode.Substring(commandEnd+1);
        }

        singleton.StateHasChanged();
        singleton.InvokeAsync(() => singleton.EnsureModulesLoaded(sourceCode));

        return sourceCode;
    }

    static string lastModuleSource="";

    private async void Run()
    {
        if (command.Trim() == "")
        {
            output = (MarkupString)"";
            outputHeading = "Please enter a call in the command box";
        }
        else
        {
            try
            {
                Module.RichTextStackTraces = true;
                var source = await JS.InvokeAsync<string>("GetUserCode");
                if (UserModule == null || source != lastModuleSource)
                {
                    var m = new Module("User", ReplUtilities);
                    m.FormattingOptions.LineSeparator = " <br> ";
                    m.FormattingOptions.ParagraphMarker = " <p> ";
                    await EnsureModulesLoaded(source);
                    m.AddDefinitions(source);
                    lastModuleSource = source;
                    UserModule = m;
                    State = State.Empty;
                }

                var topLevelSource = command;
                if (!topLevelSource.Trim().StartsWith('['))
                    topLevelSource = $"[{topLevelSource}]";
                topLevelSource = $"{topLevelSource} [PrintLocalBindings]";
                var (rawOutput, newState) = UserModule.ParseAndExecute(topLevelSource, State);
                if (rawOutput == "")
                {
                    outputHeading = "Yes";
                    output = (MarkupString)"<i>The command executed, but did not print anything</i>";
                }
                else
                {
                    output = (MarkupString)("<p>"+rawOutput);
                    outputHeading = "Output";
                }

                State = newState;
            }
            catch (CallFailedException e) when (IsTopLevelCallFailure(e))
            {
                outputHeading = "No";
                output = (MarkupString)"<i>The command did not generate an error, but it was not successful; the answer to your query is \"no\".</i>";
                lastModuleSource= "";
            }
            catch (Exception e)
            {
                outputHeading = "Error";
                output = (MarkupString)(e.Message + "<br>" + Module.StackTrace(MethodCallFrame.CurrentFrameBindings).Replace("\n", "<br>"));
                lastModuleSource = "";
            }
            await JS.InvokeVoidAsync("ScheduleMermaidRenderAndScollToEnd");
        }

        StateHasChanged();
    }

    private async Task EnsureModulesLoaded(string source)
    {
        foreach (var requirement in source.Split('\n').Where(l => l.StartsWith("require ")))
        {
            var match = Regex.Match(requirement, @"require\s+([A-Za-z0-9_]+)");
            var packageName = match.Groups[1].Value;
            if (!Editor.Packages.ContainsKey(packageName))
            {
                var code = await JS.InvokeAsync<string>("FetchPackage", packageName);
                if (code == null)
                    throw new FileNotFoundException($"Failed to load package: {packageName}");
                Editor.Packages[packageName] = code;
                NavMenu.Update();
            }
        }
    }

    private static bool IsTopLevelCallFailure(CallFailedException e) => e.Task is CompoundTask { Name: "TopLevelCall" };

    private static Module MakeReplUtilities()
    {
        var m = new Module("ReplUtilities");
        m["PrintLocalBindings"] = new GeneralPrimitive("PrintLocalBindings",
                (args, o, bindings, p, k) =>
                {
                    ArgumentCountException.Check("PrintLocalBindings", 0, args, o);
                    var locals = bindings.Frame.Locals;
                    var output = new string[locals.Length * 4];
                    var index = 0;
                    foreach (var v in locals)
                    {
                        output[index++] = v.Name.Name;
                        output[index++] = "=";
                        var value = bindings.CopyTerm(v);
                        output[index++] = Writer.TermToString(value, bindings.Unifications); //+$":{value.GetType().Name}";
                        output[index++] = TextUtilities.NewLineToken;
                    }

                    return k(o.Append(TextUtilities.FreshLineToken).Append(output), bindings.Unifications,
                        bindings.State, p);
                })
            .Arguments()
            .Documentation("StepRepl//internals",
                "Prints the values of all local variables.  There probably isn't any reason for you to use this directly, but it's used by StepRepl to print the results of queries.");
        StepGraph.AddPrimitives(m);
        m["JSLog"] = new SimplePredicate<string>("JSLog", s =>
        {
            singleton.JS.InvokeAsync<string>("LogIt", s);
            return true;
        });

        m["StartGame"] = new SimplePredicate<object[],object[]>("StartGame", (animated, stat) =>
        {
            foreach (object[] o in animated)
                GameObjectTypes[(string)o[0]] = (string)o[1];
            foreach (object[] o in stat)
                GameObjectTypes[(string)o[0]] = (string)o[1];
            singleton.JS.InvokeAsync<string>("startGame", animated, stat);
            return true;
        });

        m["AddStaticSprite"] = new SimplePredicate<string, string, float, float, bool, bool, bool>("AddStaticSprite", (name, textureFile, x, y, destroyOffScreen, explosive, immovable) =>
        {
            GameObjectTypes[name] = textureFile;
            singleton.JS.InvokeAsync<string>("addStaticSprite", name, textureFile, x, y, destroyOffScreen, explosive, immovable);
            return true;
        });

        m["AddAnimatedSprite"] = new SimplePredicate<string, string, float, float, bool, bool, bool>("AddAnimatedSprite", (name, textureFile, x, y, destroyOffScreen, explosive, immovable) =>
        {
            GameObjectTypes[name] = textureFile;
            if (!textureFile.EndsWith(".png") && !textureFile.StartsWith("http"))
                textureFile = $"spritesheets/{textureFile}.png";
            singleton.JS.InvokeAsync<string>("addAnimatedSprite", name, textureFile, x, y, destroyOffScreen, explosive, immovable);
            return true;
        });

        m["DestroyGameObject"] = new SimplePredicate<string>("DestroyGameObject", (name) =>
        {
            singleton.JS.InvokeAsync<string>("destroyGameObject", name);
            return true;
        });

        m["EatGameObject"] = new SimplePredicate<string, string>("EatGameObject", (agent, victim) =>
        {
            singleton.JS.InvokeAsync<string>("destroyGameObject", victim);
            var position = GameState[agent];
            singleton.JS.InvokeAsync<string>("gotoXY", agent, position.X, position.Y, 1);
            return true;
        });

        m["AllGameObjects"] = new SimpleFunction<object[][]>("AllGameObjects", () => GameState.Keys.Select(k => new object[] { k, GameObjectTypes[k] }).ToArray());

        m["SetConstantVelocity"] = new SimplePredicate<string, float, float>("SetConstantVelocity", (name, x, y) =>
        {
            singleton.JS.InvokeAsync<string>("setConstantVelocity", name, x, y);
            return true;
        });

        m["Stop"] = new SimplePredicate<string>("Stop", (name) =>
        {
            singleton.JS.InvokeAsync<string>("stop", name);
            return true;
        });

        m["GotoXY"] = new SimplePredicate<string, float, float, float>("GotoXY", (name, x, y, speed) =>
        {
            singleton.JS.InvokeAsync<string>("gotoXY", name, x, y, speed);
            return true;
        });

        m["GotoGameObject"] = new SimplePredicate<string, string, float>("GotoGameObject", (name, dest, speed) =>
        {
            singleton.JS.InvokeAsync<string>("gotoGameObject", name, dest, speed);
            return true;
        });

        m["SetText"] = new SimplePredicate<string, object?>("SetText", (name, text) =>
        {
            singleton.JS.InvokeAsync<string>("setText", name, text==null?"":Writer.HumanForm(text));
            return true;
        });

        m["SetTickRate"] = new SimplePredicate<int>("SetTickRate", (frames) =>
        {
            singleton.JS.InvokeAsync<string>("setTickRate", frames);
            return true;
        });

        m["Distance"] = new SimpleFunction<string, string, float>("Distance", 
            (a, b) => (GameState[a] - GameState[b]).Length());

        m["InverseDistance"] = new SimpleFunction<string, string, float>("InverseDistance",
            (a, b) => 1.0f/(GameState[a] - GameState[b]).Length());

        m["NeedState"] = new SimpleFunction<string, string, float>("NeedState", (who, what) =>
        {
            if (needStates.TryGetValue((who, what), out var state))
                return state.Value;
            return 0;
        });

        m["SetNeedState"] = new SimplePredicate<string, string, float, float>("NeedState", (who, what, growthRate, value) =>
        {
            needStates[(who, what)] = new NeedState(value, growthRate);
            return true;
        });

        m["DecrementNeedState"] = new SimplePredicate<string, string, float, float>("NeedState", (who, what, growthRate, value) =>
        {
            if (!needStates.TryGetValue((who, what), out var state))
                state = NeedState.Empty;
            needStates[(who, what)] = new NeedState(Math.Max(0, Math.Min(100, state.Value-value)), growthRate);
            return true;
        });

        return m;
    }

    public static bool RetainState = true;
    public static Task? CommandProcessor;

    private static Home singleton=null!;
    protected override void OnInitialized()
    {
        singleton = this;
        Module.RequireHook = (packageName) =>         {
            if (Editor.Packages.TryGetValue(packageName, out var code))
                return new StringReader(code);
            throw new Exception($"Package not found: {packageName}");
        };

        if (!string.IsNullOrEmpty(lastModuleSource))
        {
            JS.InvokeVoidAsync("SetUserCode", lastModuleSource);
        }
    }

    public async ValueTask DisposeAsync()
    {
        lastModuleSource = await JS.InvokeAsync<string>("GetUserCode");
    }

    #region Game stuff
    private static readonly Dictionary<string, Vector2> GameState = new();
    private static readonly Dictionary<string, string> GameObjectTypes = new();

    [JSInvokable]
    public static void ProcessGameNotifications(object[] notifications, JsonElement[][] gameState)
    {
        singleton.ReallyProcessGameNotifications(notifications, gameState);
    }

    public void ReallyProcessGameNotifications(object[] notifications, JsonElement[][] gameState)
    {
        GameState.Clear();
        foreach (var tuple in gameState)
        {
            var name = tuple[0].GetString()!;
            var x = tuple[1].GetSingle();
            var y = tuple[2].GetSingle();
            GameState[name] = new Vector2(x, y);
        }

        object? current = null;
        try
        {
            foreach (var n in notifications)
            {
                current = n is JsonElement e ? DecodeJsonElement(e) : n;
                var (text, newState) = UserModule.Call(State, "GameEvent", current);
                State = newState;
                output = (MarkupString)(output.Value + text);
            }
        }
        catch (Exception e)
        {
            outputHeading = $"Error processing game event: {Writer.TermToString(current)}";
            output = (MarkupString)(e.Message + "<br>" + Module.StackTrace(MethodCallFrame.CurrentFrameBindings).Replace("\n", "<br>"));
            StateHasChanged();
        }
    }

    object? DecodeJsonElement(JsonElement e) =>
        e.ValueKind switch
        {
            JsonValueKind.Array => e.EnumerateArray().Select(DecodeJsonElement).ToArray(),
            JsonValueKind.String => e.GetString(),
            JsonValueKind.Number => e.GetSingle(),
            JsonValueKind.True => true,
            JsonValueKind.False => false,
            JsonValueKind.Null => null,
            _ => "unknownObject"
        };

    public readonly struct NeedState
    {
        private readonly float Snapshot;
        private readonly int Timestamp;
        public readonly float GrowthRate;

        public static readonly NeedState Empty = new NeedState(0, 0, 0);

        private NeedState(float snapshot, int timestamp, float growthRate)
        {
            Snapshot = snapshot;
            Timestamp = timestamp;
            GrowthRate = growthRate;
        }

        public NeedState(float value, float growthRate) : this(value, Environment.TickCount, growthRate)
        { }

        public int TicksSinceReading => Environment.TickCount - Timestamp;
        public float SecondsSinceReading => TicksSinceReading / 1000f;

        public float Value => Math.Min(100, Snapshot + SecondsSinceReading * GrowthRate);
    }

    private static readonly Dictionary<(string, string), NeedState> needStates = new ();
    #endregion
}

<p></p>
<h3>@outputHeading</h3>

<p id="codeOutput" role="status">@output</p>


